# Aqarkom Environment Configuration
# Copy to .env and adjust values

# Database (PostgreSQL)
DATABASE_URL=postgresql://aqarkom:aqarkom@localhost:5432/aqarkom

# Redis (optional; used for rate limiting, future cache/sessions)
# When set, rate limit uses Redis; otherwise in-memory. Use with docker-compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# API Server
PORT=3000

# Authentication - use a strong secret in production
JWT_SECRET=your-secret-key-change-in-production

# Optional: Node environment
NODE_ENV=development

# Google Maps (for search map at /search - apps/web)
# Get a key: https://developers.google.com/maps/documentation/javascript/get-api-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
