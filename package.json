{
  "name": "aqarkom",
  "version": "1.0.0",
  "private": true,
  "description": "Aqarkom - Arabic-first Saudi Real Estate CRM",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:web": "pnpm --filter @aqarkom/web dev",
    "dev:api": "pnpm --filter @aqarkom/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm build",
    "build:web": "pnpm --filter @aqarkom/web build",
    "build:api": "pnpm --filter @aqarkom/api build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install:all": "playwright install",
    "load:property-search": "k6 run load-tests/property-search.js",
    "load:auth": "k6 run load-tests/auth.js",
    "db:migrate": "pnpm --filter @aqarkom/api db:migrate",
    "db:seed": "pnpm --filter @aqarkom/api exec tsx src/seed.ts",
    "worker": "pnpm --filter @aqarkom/api worker"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.14.2",
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
